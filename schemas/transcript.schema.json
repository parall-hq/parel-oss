{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.parel.sh/v1/transcript.schema.json",
  "title": "PAREL Transcript",
  "description": "A session transcript as an ordered list of PAREL messages.",
  "type": "object",
  "required": ["messages"],
  "properties": {
    "sessionId": { "type": "string" },
    "messages": {
      "type": "array",
      "items": { "$ref": "https://schemas.parel.sh/v1/message.schema.json" }
    }
  },
  "additionalProperties": false
}

