{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.parel.sh/v1/api-error.schema.json",
  "title": "PAREL API Error",
  "description": "Common public API error envelope.",
  "type": "object",
  "required": ["error"],
  "properties": {
    "error": {
      "type": "string"
    },
    "details": true,
    "code": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Stable machine-readable error code; additive, optional. Lowercase snake_case (e.g. agent_not_found)."
    },
    "request_id": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

