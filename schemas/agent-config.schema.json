{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.parel.sh/v1/agent-config.schema.json",
  "title": "PAREL Agent Config",
  "description": "Public schema for agent.yaml.",
  "type": "object",
  "required": ["version", "model"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1"
    },
    "agent": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "model": {
      "type": "object",
      "required": ["provider", "model"],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1,
          "description": "Model provider alias: anthropic, openai, openai-responses, or openai-compatible / anthropic-compatible (set config.baseUrl + a BYOK key for any compatible endpoint)."
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "plugins": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/pluginDeclaration"
      }
    },
    "runtime": {
      "type": "object",
      "default": {},
      "properties": {
        "maxTurns": {
          "type": "integer",
          "minimum": 0
        },
        "maxSteps": {
          "type": "integer",
          "minimum": 0
        },
        "durability": {
          "type": "string",
          "enum": ["event-sourced", "ephemeral"]
        },
        "checkpointInterval": {
          "type": "integer",
          "minimum": 1
        },
        "maxParallelToolCalls": {
          "type": "integer",
          "minimum": 1
        },
        "toolResultMaxBytes": {
          "type": "integer",
          "minimum": 1
        },
        "reasoning": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "budgetTokens": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "pluginDeclaration": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": ["plugin"],
          "properties": {
            "plugin": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1,
              "description": "Optional semver range to freeze at deploy or session provisioning time."
            },
            "source": {
              "$ref": "#/$defs/pluginSource"
            },
            "config": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 1,
          "patternProperties": {
            "^.+$": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "pluginSource": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "path"],
          "properties": {
            "type": {
              "type": "string",
              "const": "path"
            },
            "path": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
