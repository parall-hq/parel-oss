{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.parel.sh/v1/agent-config.schema.json",
  "title": "PAREL Agent Config",
  "description": "Public schema for agent.yaml.",
  "type": "object",
  "required": [
    "version",
    "model"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1"
    },
    "agent": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "model": {
      "type": "object",
      "required": [
        "provider",
        "model"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1,
          "description": "Model provider alias: anthropic, openai, openai-responses, or openai-compatible / anthropic-compatible (set config.baseUrl + a BYOK key for any compatible endpoint)."
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "plugins": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/pluginDeclaration"
      }
    },
    "runtime": {
      "type": "object",
      "default": {},
      "properties": {
        "maxTurns": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "$ref": "#/$defs/instanceVarRef"
            }
          ]
        },
        "maxSteps": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "$ref": "#/$defs/instanceVarRef"
            }
          ]
        },
        "instanceBudgetUsd": {
          "description": "Instance-level spend ceiling in USD: once total cost across all sessions of an agent instance reaches this, new turns are refused until the budget is raised (enforced with one-turn lag).",
          "oneOf": [
            {
              "type": "number",
              "exclusiveMinimum": 0
            },
            {
              "$ref": "#/$defs/instanceVarRef"
            }
          ]
        },
        "durability": {
          "type": "string",
          "enum": [
            "event-sourced",
            "ephemeral"
          ]
        },
        "checkpointInterval": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "$ref": "#/$defs/instanceVarRef"
            }
          ]
        },
        "maxParallelToolCalls": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "$ref": "#/$defs/instanceVarRef"
            }
          ]
        },
        "toolResultMaxBytes": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "$ref": "#/$defs/instanceVarRef"
            }
          ]
        },
        "reasoning": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "properties": {
            "enabled": {
              "oneOf": [
                {
                  "type": "boolean"
                },
                {
                  "$ref": "#/$defs/instanceVarRef"
                }
              ]
            },
            "budgetTokens": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 1
                },
                {
                  "$ref": "#/$defs/instanceVarRef"
                }
              ]
            }
          },
          "additionalProperties": false
        },
        "deploymentTracking": {
          "type": "string",
          "enum": [
            "live",
            "pinned"
          ],
          "description": "Whether sessions follow the agent's active deployment at turn boundaries (live, default) or keep their creation-time config and plugin lock forever (pinned)."
        }
      },
      "additionalProperties": false
    },
    "channels": {
      "type": "array",
      "description": "Declarative channel connector bindings provisioned at deploy time (frozen connector + connection + agent binding). Additive to the control-plane channel API.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "plugin"
        ],
        "properties": {
          "type": {
            "enum": [
              "webhook",
              "managed_ws"
            ],
            "description": "Connection transport: inbound webhook, or host-managed outgoing WebSocket."
          },
          "plugin": {
            "type": "string",
            "minLength": 1,
            "description": "Connector plugin package, e.g. \"@parel/channel-slack-socket\"."
          },
          "version": {
            "type": "string",
            "minLength": 1,
            "description": "Optional connector semver range; frozen to an exact version at deploy time."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Disambiguator when one agent declares multiple connections of the same (type, plugin)."
          },
          "config": {
            "type": "object",
            "description": "Connector config; values may be ${SECRET_REF} references resolved at the org scope."
          },
          "start": {
            "type": "boolean",
            "description": "For managed_ws, whether to start the connection at deploy time (default true)."
          },
          "routing": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "mode"
            ],
            "properties": {
              "mode": {
                "enum": [
                  "main",
                  "per_subject",
                  "per_actor",
                  "isolated"
                ],
                "description": "Conversation split policy for the auto-created binding (default \"main\")."
              },
              "injectInFlight": {
                "type": "boolean",
                "description": "Opt-in mid-turn injection: events arriving for the running turn's exact (connection, subject) group are materialized at the next step boundary instead of waiting for the turn to end; different-subject events stay queued even when they resolve to the same session (default false)."
              }
            }
          },
          "instance": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$",
            "description": "Agent instance the binding routes conversations into (default \"main\"). Every conversation split shares this instance's entity state (sandbox, memory)."
          },
          "observe": {
            "type": "array",
            "items": {
              "enum": [
                "turn",
                "steps",
                "pause"
              ]
            },
            "description": "Agent-event push scopes for the auto-created binding (opt-in; omitted = no pushes)."
          },
          "childSessions": {
            "type": "boolean",
            "description": "Opt-in connector-spawned fork child sessions via the spawnChildSession effect; requires routing.mode \"main\" (default false)."
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "instanceVarRef": {
      "type": "string",
      "pattern": "^\\$\\{var:[A-Za-z_][A-Za-z0-9_]*\\}$",
      "description": "Whole-value instance-var reference. The hosted runtime substitutes the instance's var at turn boundaries (type-aware: a value that parses as the field's number/boolean type substitutes as that type) and re-validates the field there; an unset var or a value of the wrong type fails the turn before any model call. Typed runtime knobs only — durability and deploymentTracking never take references, and a ref embedded in a longer string does not qualify."
    },
    "pluginDeclaration": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": [
            "plugin"
          ],
          "properties": {
            "plugin": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1,
              "description": "Optional semver range to freeze at deploy or session provisioning time."
            },
            "source": {
              "$ref": "#/$defs/pluginSource"
            },
            "config": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 1,
          "patternProperties": {
            "^.+$": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "pluginSource": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "type": "string",
              "const": "path"
            },
            "path": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
