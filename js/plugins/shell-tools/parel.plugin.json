{
  "$schema": "../../../schemas/plugin-manifest.schema.json",
  "name": "@parel/shell-tools",
  "version": "0.1.1",
  "description": "Workspace-rooted shell command execution tool.",
  "provides": {
    "tools": true
  },
  "requires": {
    "capabilities": ["workspace", "exec"]
  },
  "execution": {
    "snapshot": {
      "store": "reset",
      "sideEffects": "require_approval"
    }
  }
}
